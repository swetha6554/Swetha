<!DOCTYPE html>
<html>
    <head>
        <style>
             .parent{
                background-color: black;
                height:800px;
                width:600px;
                padding:20px;
                gap:20px;
                display:grid;
                grid-template-columns: 100px 100px 100px;
                grid-template-rows: 150px 150px;   
            } 
            .childern
            {
                background-color: rgb(94, 116, 108);
                display:grid;
                gap:10px;   
            }
        
        @media (max-width:600px)
        {
        .childern
        {
            background-color: beige;
        }
        }

        </style>
    </head>
    <body>
        <div class="parent">
            <div class="childern"></div>
            <div class="childern"></div>
            <div class="childern"></div>
            <div class="childern"></div>
            <div class="childern"></div>
            <div class="childern"></div>
        </div>

    </body>
</html>
